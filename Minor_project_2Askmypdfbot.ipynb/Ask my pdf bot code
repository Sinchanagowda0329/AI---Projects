        "# =========================================================\n",
        "# ASK MY PDF BOT (FINAL FIXED WORKING CODE)\n",
        "# RAG + FAISS + GPT2 + PDF QUESTION ANSWERING\n",
        "# =========================================================\n",
        "\n",
        "# STEP 1: Install Libraries\n",
        "!pip install -q transformers\n",
        "!pip install -q sentence-transformers\n",
        "!pip install -q faiss-cpu\n",
        "!pip install -q pypdf\n",
        "!pip install -q torch\n",
        "\n",
        "# STEP 2: Import Libraries\n",
        "from pypdf import PdfReader\n",
        "from sentence_transformers import SentenceTransformer\n",
        "from transformers import pipeline\n",
        "\n",
        "import faiss\n",
        "import numpy as np\n",
        "\n",
        "# STEP 3: Upload PDF\n",
        "from google.colab import files\n",
        "\n",
        "uploaded = files.upload()\n",
        "\n",
        "pdf_path = list(uploaded.keys())[0]\n",
        "\n",
        "print(\"PDF Uploaded:\", pdf_path)\n",
        "\n",
        "# STEP 4: Read PDF\n",
        "reader = PdfReader(pdf_path)\n",
        "\n",
        "text = \"\"\n",
        "\n",
        "for page in reader.pages:\n",
        "\n",
        "    page_text = page.extract_text()\n",
        "\n",
        "    if page_text:\n",
        "        text += page_text\n",
        "\n",
        "print(\"PDF Loaded Successfully\")\n",
        "\n",
        "# STEP 5: Split Text into Chunks\n",
        "chunks = []\n",
        "\n",
        "chunk_size = 500\n",
        "\n",
        "for i in range(0, len(text), chunk_size):\n",
        "\n",
        "    chunk = text[i:i + chunk_size]\n",
        "\n",
        "    chunks.append(chunk)\n",
        "\n",
        "print(\"Total Chunks:\", len(chunks))\n",
        "\n",
        "# STEP 6: Load Embedding Model\n",
        "embed_model = SentenceTransformer(\n",
        "    \"sentence-transformers/all-MiniLM-L6-v2\"\n",
        ")\n",
        "\n",
        "print(\"Embedding Model Loaded\")\n",
        "\n",
        "# STEP 7: Create Embeddings\n",
        "embeddings = embed_model.encode(chunks)\n",
        "\n",
        "embedding_array = np.array(embeddings).astype(\"float32\")\n",
        "\n",
        "print(\"Embeddings Created\")\n",
        "\n",
        "# STEP 8: Create FAISS Index\n",
        "dimension = embedding_array.shape[1]\n",
        "\n",
        "index = faiss.IndexFlatL2(dimension)\n",
        "\n",
        "index.add(embedding_array)\n",
        "\n",
        "print(\"FAISS Index Ready\")\n",
        "\n",
        "# STEP 9: Load GPT2 Model\n",
        "qa_pipeline = pipeline(\n",
        "    \"text-generation\",\n",
        "    model=\"gpt2\"\n",
        ")\n",
        "\n",
        "print(\"LLM Loaded Successfully\")\n",
        "\n",
        "# STEP 10: Chat Loop\n",
        "while True:\n",
        "\n",
        "    question = input(\"\\nAsk Question From PDF (type exit): \")\n",
        "\n",
        "    if question.lower() == \"exit\":\n",
        "\n",
        "        print(\"Chatbot Closed\")\n",
        "\n",
        "        break\n",
        "\n",
        "    # Convert Question into Embedding\n",
        "    q_embedding = embed_model.encode([question])\n",
        "\n",
        "    q_embedding = np.array(q_embedding).astype(\"float32\")\n",
        "\n",
        "    # Search Similar Chunks\n",
        "    distances, indices = index.search(q_embedding, k=3)\n",
        "\n",
        "    # Retrieve Context\n",
        "    context = \"\"\n",
        "\n",
        "    for idx in indices[0]:\n",
        "\n",
        "        context += chunks[idx] + \"\\n\"\n",
        "\n",
        "    # Create Prompt\n",
        "    prompt = f\"\"\"\n",
        "    Use the context below to answer the question.\n",
        "\n",
        "    Context:\n",
        "    {context}\n",
        "\n",
        "    Question:\n",
        "    {question}\n",
        "\n",
        "    Answer:\n",
        "    \"\"\"\n",
        "\n",
        "    # Generate Answer\n",
        "    result = qa_pipeline(\n",
        "        prompt,\n",
        "        max_new_tokens=100,\n",
        "        do_sample=False\n",
        "    )\n",
        "\n",
        "    # Print Answer\n",
        "    answer = result[0][\"generated_text\"]\n",
        "\n",
        "    print(\"\\nANSWER:\")\n",
        "    print(answer)"
      ],
